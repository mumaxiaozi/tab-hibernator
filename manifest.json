{
  "manifest_version": 3,
  "name": "Tab Hibernator - 标签页休眠助手",
  "version": "1.0.0",
  "description": "自动休眠不活跃的标签页，释放内存占用。支持白名单、自定义超时、一键休眠和内存统计。",
  "permissions": [
    "tabs",
    "storage",
    "alarms",
    "system.memory"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
